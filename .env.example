# ─────────────────────────────────────────────────────────────
# Y2KASE Shopify — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# myshopify.com hostname
SHOPIFY_SHOP=y2kase-1435.myshopify.com

# Dev Dashboard app (client credentials grant → Admin API token)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Admin API bearer token (minted from id/secret; expires — refresh in automation)
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Storefront API token (Headless / Storefront access)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

SHOPIFY_API_VERSION=2025-01
